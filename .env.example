# Development: leave empty to use Vite proxy (same origin → /v1).
# Production: public API origin, e.g. https://api.example.com
VITE_API_URL=

# Dev proxy → backend (read by vite.config.ts via loadEnv)
VITE_BACKEND_PORT=3000

# Optional: full origin if port alone is not enough (Docker, other host)
# VITE_PROXY_TARGET=http://127.0.0.1:3000
